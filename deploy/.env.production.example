# Copy to deploy/.env.production in the deployment secret store. Do not commit it.
# Include every required server-side value from the repository-root .env.example.
LOVART_DOFE_WEB_ORIGIN=https://lovart.example.com
SSO_REDIRECT_URI=https://lovart.example.com/auth/callback
NEXT_PUBLIC_SERVER_BASE_URL=https://lovart.example.com
# Required in every production API instance. Use a TLS-enabled managed Redis
# endpoint so anonymous auth-transfer telemetry is limited across replicas.
REDIS_URL=rediss://:replace-with-secret@redis.example.com:6380/5
