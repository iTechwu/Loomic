# ══════════════════════════════════════════════════════════════════════
# lovart.dofe Environment Variables
# ══════════════════════════════════════════════════════════════════════
# Copy to .env.local (local dev) or .env.cloud (cloud deploy).
# Values marked [required] must be set; others have sensible defaults.

# ── Server ─────────────────────────────────────────────────────────
LOVART_DOFE_SERVER_PORT=3105
LOVART_DOFE_WEB_ORIGIN=https://lovart.local.dofe.ai
NEXT_PUBLIC_SERVER_BASE_URL=https://lovart.local.dofe.ai # API is reverse-proxied at /api/
# Public, explicit SSO Web URL. Do not derive this from SSO_API_URL.
NEXT_PUBLIC_SSO_ACCOUNT_URL=https://sso.ixicai.cn/settings/security

# ── Native PostgreSQL + Volcengine TOS (required data plane) ──────
# Server-only. Do not expose DATABASE_URL or any TOS_* value with NEXT_PUBLIC_.
DATABASE_URL=postgresql://dofe:change-me@127.0.0.1:5432/lovart_dofe
TOS_ACCESS_KEY=your-tos-access-key
TOS_SECRET_KEY=your-tos-secret-key
TOS_REGION=your-tos-region
TOS_ENDPOINT=https://tos-endpoint.example.com
TOS_INTERNAL_ENDPOINT=https://tos-internal-endpoint.example.com
TOS_S3_ENDPOINT=https://tos-s3-endpoint.example.com
TOS_INTERNAL_S3_ENDPOINT=https://tos-internal-s3-endpoint.example.com
TOS_BUCKET=lovart-dofe
TOS_BUCKET_DOMAIN=https://cdn.example.com
TOS_INTERNAL_BUCKET_DOMAIN=https://cdn-internal.example.com

# ── Redis + RabbitMQ (required for cache and async jobs) ──────────
REDIS_URL=redis://:your-password@127.0.0.1:6379/5
RABBITMQ_URL=amqp://dofe:your-password@127.0.0.1:5672/lovart_dofe

# SSO / OpenID Connect (required for login; keep real secrets in .env.local only)
SSO_API_URL=https://sso.ixicai.cn/api
SSO_INTERNAL_API_URL=https://sso.ixicai.cn/api
SSO_ISSUER=https://sso.ixicai.cn/api
SSO_CLIENT_ID=lovart-dofe-ai-local
SSO_CLIENT_SECRET=replace-with-client-secret
SSO_SERVICE_NAME=lovart.local.dofe.ai
INTERNAL_API_SECRET=replace-with-server-only-secret
SSO_REDIRECT_URI=https://lovart.local.dofe.ai/auth/callback
JWKS_PATH=.well-known/jwks.json
JWKS_URI=https://sso.ixicai.cn/api/.well-known/jwks.json
INTERNAL_JWKS_URI=https://sso.ixicai.cn/api/.well-known/jwks.json
SSO_DISCOVERY_URL=https://sso.ixicai.cn/api/.well-known/openid-configuration

# ── Agent LLM ─────────────────────────────────────────────────────
LOVART_DOFE_AGENT_BACKEND_MODE=state                          # "state" (default) or "filesystem"
LOVART_DOFE_AGENT_MODEL=dofe:gpt-5.4                          # format: <provider>:<model-id>
# DoFe Models Router (recommended). https://ixicai.cn is normalized to /api.
# Model routing uses native protocol endpoints: Gemini → /gemini; Claude →
# /anthropic; other text models → OpenAI-compatible /v1. Image/video generation
# flows through the multimodal /v1/generation/tasks endpoint. Every per-user
# model call authenticates with that user's provisioned design apikey (strict
# per-user isolation; no shared-key fallback at call time).
DOFE_MODEL_BASE_URL=https://ixicai.cn
# Read-only catalog key used only to probe GET /v1/models for the model picker.
# Real user calls never use this key — they use each user's provisioned key.
DOFE_MODEL_API_KEY=replace-with-dofe-model-api-key

# ── Per-user models credential provisioning ──────────────────────
# Service name signed into the HMAC bearer for POST /internal/seedance/credentials.
# Must be whitelisted on the models side (lovart.dofe.ai is on the default list).
LOVART_MODELS_SERVICE_NAME=lovart.dofe.ai
# Provisioning auth reuses INTERNAL_API_SECRET (defined in the SSO section above)
# — it must equal models.dofe.ai's INTERNAL_API_SECRET.
# AES-256-GCM key (32 bytes: base64 / hex / 32-char utf8) for encrypting
# provisioned credentials at rest. It is required whenever credential
# provisioning is enabled; Lovart will not fall back to plaintext storage.
# LOVART_CREDENTIAL_ENCRYPTION_KEY=
# Direct providers are only used when DOFE_MODEL_* is absent.
# Provider "openai" → needs OPENAI_API_KEY (+ optional OPENAI_API_BASE for direct proxy)
# Provider "google" → needs GOOGLE_API_KEY
OPENAI_API_KEY=                                          # optional, for openai provider
OPENAI_API_BASE=                                         # optional, custom endpoint / proxy
GOOGLE_API_KEY=                                          # optional, for google provider + Veo video + Imagen image

# ── Image / Video Generation ─────────────────────────────────────
# All image/video models now run through the DoFe (ixicai.cn) gateway with
# per-user credentials (see DOFE_MODEL_* and provisioning section above). The
# direct providers below are no longer registered and are kept only as a
# reference / rollback path.
# REPLICATE_API_TOKEN=                                    # deprecated (was 13 Replicate models)
# GOOGLE_API_KEY (above) no longer drives image/video — chat fallback only.

# ── Google Vertex AI (optional, coexists with Developer API) ────
# Uses GCP service account for auth. Both Developer API and Vertex AI
# can be configured simultaneously — they register as separate providers.
GOOGLE_APPLICATION_CREDENTIALS=                          # path to service account JSON (e.g., ./credentials/vertex-ai-sa.json)
GOOGLE_VERTEX_PROJECT=                                   # GCP project ID (e.g., my-project-123456)
GOOGLE_VERTEX_LOCATION=                                  # GCP region (e.g., us-central1)

# ── Skills & Sandbox ─────────────────────────────────────────────
# Local dev: relative from apps/server/ cwd → ../../skills
# Docker/Railway: /opt/lovart-dofe/skills (Dockerfile copies skills/ there)
LOVART_DOFE_SKILLS_ROOT=../../skills

# ── Worker (optional, defaults shown) ────────────────────────────
# WORKER_CODE_CONCURRENCY=3
# WORKER_IMAGE_CONCURRENCY=3
# WORKER_VIDEO_CONCURRENCY=2
# WORKER_POLL_INTERVAL_MS=2000

# ── Misc ─────────────────────────────────────────────────────────
GOOGLE_FONTS_API_KEY=                                    # optional, brand kit font picker
# VOLCES_API_KEY=                                        # optional, TTS
# VOLCES_BASE_URL=                                       # optional, TTS

# ── Local dev only ───────────────────────────────────────────────
# GLOBAL_AGENT_HTTP_PROXY=http://127.0.0.1:7890          # HTTP proxy for outbound requests
