{
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @lovart.dofe/shared build && pnpm --filter @lovart.dofe/web build",
  "outputDirectory": "apps/web/out",
  "cleanUrls": true,
  "redirects": [
    { "source": "/login", "destination": "/api/auth/oidc/start?returnTo=%2Fhome", "permanent": false },
    { "source": "/register", "destination": "/api/auth/oidc/start?returnTo=%2Fhome", "permanent": false }
  ],
  "rewrites": [
    { "source": "/((?!api(?:/|$)|_next|favicon|logo|og-image|apple-touch-icon).*)", "destination": "/index.html" }
  ]
}
