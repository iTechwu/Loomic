{
  "name": "@lovart.dofe/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "10.3.0",
    "@fastify/websocket": "^11.2.0",
    "@google/genai": "^1.47.0",
    "@langchain/anthropic": "1.1.0",
    "@langchain/core": "^1.1.35",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/google-vertexai": "^2.1.26",
    "@langchain/langgraph": "^1.2.5",
    "@langchain/langgraph-checkpoint": "^1.0.1",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.1",
    "@langchain/openai": "^1.3.0",
    "@lovart.dofe/shared": "workspace:*",
    "@volcengine/tos-sdk": "^2.9.1",
    "amqplib": "^0.10.9",
    "deepagents": "^1.8.4",
    "fastify": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "ioredis": "^5.11.1",
    "jose": "^6.2.2",
    "js-yaml": "^4.1.1",
    "langchain": "^1.2.36",
    "openai": "^6.32.0",
    "pg": "^8.20.0",
    "sharp": "^0.34.5",
    "tar": "^7.5.13",
    "undici": "^7.24.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@lovart.dofe/config": "workspace:*",
    "@types/amqplib": "^0.10.8",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.20.0",
    "@types/sharp": "^0.32.0",
    "@types/tar": "^7.0.87",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.3",
    "vitest": "^3.2.4",
    "ws": "^8.18.1"
  },
  "scripts": {
    "build": "node ../../scripts/validate-foundation-app.mjs build",
    "predev": "pnpm --filter @lovart.dofe/shared build",
    "dev": "node --watch --env-file=../../.env.local --import tsx ./src/server.ts & WORKER_ID=w1 node --watch --env-file=../../.env.local --import tsx ./src/worker.ts & wait",
    "dev:server": "node --watch --env-file=../../.env.local --import tsx ./src/server.ts",
    "dev:worker": "node --watch --env-file=../../.env.local --import tsx ./src/worker.ts",
    "dev:workers:2": "WORKER_ID=w1 node --watch --env-file=../../.env.local --import tsx ./src/worker.ts & WORKER_ID=w2 node --watch --env-file=../../.env.local --import tsx ./src/worker.ts & wait",
    "dev:workers:3": "WORKER_ID=w1 node --watch --env-file=../../.env.local --import tsx ./src/worker.ts & WORKER_ID=w2 node --watch --env-file=../../.env.local --import tsx ./src/worker.ts & WORKER_ID=w3 node --watch --env-file=../../.env.local --import tsx ./src/worker.ts & wait",
    "db:migrate": "node --env-file=../../.env.local --import tsx ./src/database/migrate.ts",
    "worker": "node --env-file=../../.env.local --import tsx ./src/worker.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
